# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://"
# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-string"

# GitHub OAuth App
GITHUB_ID="your_github_oauth_client_id"
GITHUB_SECRET="your_github_oauth_client_secret"

# GitHub App / Webhooks
GITHUB_WEBHOOK_SECRET="your_webhook_signature_secret"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Slack Integration
# Required: Incoming Webhook URL from your Slack App (api.slack.com)
# The URL itself is the credential — treat it like a password, never commit it.
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Optional: Retry configuration for failed Slack notifications
SLACK_MAX_RETRIES=3        # Number of delivery attempts before giving up (default: 3)
SLACK_RETRY_BASE_MS=1000   # Base delay for exponential backoff in ms (default: 1000)