generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// NextAuth Standard Tables
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Custom relations
  repositories Repository[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Application Core Tables
// ==========================================

model Repository {
  id       String @id @default(cuid())
  githubId Int    @unique
  name     String
  fullName      String   // e.g., "owner/repo"
  url           String
  webhookSecret String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rules         Rule[]
  webhookEvents WebhookEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Rule {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  eventType     String // e.g., "pull_request", "issues", "push"
  conditions    Json // Conditions to evaluate (e.g., title contains "WIP")
  actionType    String // e.g., "add_label", "send_slack_message"
  actionPayload Json // Payload for the action (e.g., { "label": "bug" })

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  actionLogs ActionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Composite index: Quickly find rules for a specific event type on a specific repository
  @@index([repositoryId, eventType])
}

model WebhookEvent {
  id               String @id @default(cuid())
  githubDeliveryId String @unique // X-GitHub-Delivery header to strictly prevent duplication

  event   String // X-GitHub-Event header (e.g., "pull_request")
  action  String? // Action from payload (e.g., "opened", "closed")
  payload Json // The raw GitHub webhook payload

  status EventStatus @default(PENDING)

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  actionLogs ActionLog[]

  createdAt DateTime @default(now())

  // Composite index: Quickly query pending events for a repository
  @@index([repositoryId, status])
}

model ActionLog {
  id String @id @default(cuid())

  actionType   String // Duplicated from rule to keep historical record if rule changes/is deleted
  status       ActionStatus @default(PENDING)
  errorMessage String?      @db.Text

  eventId String
  event   WebhookEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // SetNull: If a rule is deleted, we still want to keep the historical action log
  ruleId String?
  rule   Rule?   @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([ruleId])
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
  IGNORED
}

enum ActionStatus {
  PENDING
  SUCCESS
  FAILED
}
